# PASS24 Parser — переменные окружения
# Скопируйте в .env и заполните значения

# 2GIS API (опционально, можно парсить без ключа)
# TWOGIS_API_KEY=

# Bitrix24 REST API (для автоматического экспорта)
# BITRIX24_WEBHOOK_URL=https://pass24pro.bitrix24.ru/rest/1/xxxxx/

# AI Sales Factory webhook (для экспорта лидов)
# AI_SALES_WEBHOOK_URL=https://your-ai-sales-domain/webhooks/lead-form

# Настройки парсинга
# PARSER_REGION=moscow_oblast
# PARSER_PAUSE_SECONDS=2.0
# PARSER_HTTP_TIMEOUT=18
